{
  "name": "base-ui",
  "version": "0.1.0",
  "description": "A production-ready React 19 component library built with Vite, TypeScript, and Storybook.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type-check": "tsc --noEmit --emitDeclarationOnly false",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint . && npm run lint:scss",
    "lint:scss": "stylelint '**/*.scss'",
    "lint:scss:fix": "stylelint '**/*.scss' --fix",
    "format": "biome format . --write && npm run format:scss",
    "format:check": "biome format . --check",
    "format:scss": "prettier --write '**/*.scss'",
    "format:scss:check": "prettier --check '**/*.scss'",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishonly": "npm run type-check && npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@storybook/addon-a11y": "latest",
    "@storybook/react": "latest",
    "@storybook/react-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "@vitest/ui": "latest",
    "classnames": "^2.5.1",
    "jsdom": "latest",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sass": "latest",
    "storybook": "latest",
    "stylelint": "^17.6.0",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "latest",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "latest"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/base-ui"
  },
  "bugs": {
    "url": "https://github.com/yourusername/base-ui/issues"
  },
  "homepage": "https://github.com/yourusername/base-ui"
}
